#include <stdio.h>

float h(int n){

    int i;
    float h, acumulador = 0;

    for (i=1; i<=n; i++){
        h = 1.0/i;
        acumulador += h;
    }
    return acumulador;
}

int main(){

    int x;
    float y;

    printf("Digite o numero de termos n: ");
    scanf("%d", &x);

    y = h(x);

    printf("O valor de h e: %.8f", y);

    return 0;
}
