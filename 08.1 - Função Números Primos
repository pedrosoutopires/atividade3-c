#include <stdio.h>

int primo(int numero){

    int i, divisores = 0;

    for (i = 1; i <= numero; i++){

        if (numero % i == 0){
        divisores++;
        }
    }
            if (divisores == 2){
                return 1;
            }
            else {
                return 0;
            }
}


int main(){

    int x, y;

    printf("Digite um numero: ");
    scanf("%d", &x);

    y = primo(x);

    printf("1 - PRIMO \n0 - NAO PRIMO \n\n%d", y);

    return 0;
}
