#include <stdio.h>

int main(){

    int i;
    float numero, maior, menor;

    scanf("%f", &numero);

    maior = numero;
    menor = numero;

    for (i = 1; i <= 9; i++){

        scanf("%f", &numero);

        if (numero >= maior){
            maior = numero;
        }
        if (numero <= menor){
            menor = numero;
        }
    }
    printf("O maior e o menor sao, respectivamente: %.2f e %.2f", maior, menor);

    return 0;
}
