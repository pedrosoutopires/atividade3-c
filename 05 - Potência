#include <stdio.h>

int potencia(int x, int y) {

    int resultado = 1;

    for (int i = 0; i < y; i++)
    {
        resultado *= x;
    }

    return resultado;
}

int main(){

    int a, b, total;

    printf("Digite uma base e uma potencia: ");
    scanf("%d%d", &a, &b);

    total = potencia(a, b);

    printf("%d", total);

    return 0;
}
