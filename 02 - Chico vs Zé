#include <stdio.h>

int main(){

    int anos = 0;
    float alturachico = 1.50, alturaze = 1.10;

    while(alturaze <= alturachico){
        anos ++;
        alturachico = alturachico + 0.02;
        alturaze = alturaze + 0.03;
    }

    printf("o numero de anos sao: %d anos", anos);

    return 0;

}
