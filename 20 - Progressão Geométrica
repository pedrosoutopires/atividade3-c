#include <stdio.h>

int main(){

    int a1, r, n, i;

    printf("Digite o primeiro termo: ");
    scanf("%d", &a1);
    printf("Digite a razao: ");
    scanf("%d", &r);
    printf("Digite o numero de termos: ");
    scanf("%d", &n);

    for (i=1; i<=n; i++){
        printf("%d ", a1);
        a1 = a1 * r;
    }
    return 0;
}
