#include <stdio.h>

int main() {
    int filhos, pessoas = 0, somafilhos = 0, salarioabaixo = 0;
    float salario, mediasalario, salarioacumulativo = 0, maiorsalario = 0;

    do {
        printf("me informe o salario e o numero de filhos: ");
        scanf("%f%d", &salario, &filhos);

        pessoas++;

        salarioacumulativo += salario;
        somafilhos += salario;

        if(salario >= maiorsalario)
        maiorsalario = salario;

        if(salario <=100)
        salarioabaixo++;
    }
        while(salario >= 0);


    printf("\na media salarial e: %.2f", salarioacumulativo/pessoas);
    printf("\na media de filhos e: %d", somafilhos/pessoas);
    printf("\no maior salario e: %.2f", maiorsalario);
    printf("\no percentual de pessoas com salario ate R$100,00 e: %.2f PORCENTO", ((float)salarioabaixo/pessoas) * 100);

    return 0;

    }
